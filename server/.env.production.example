# Server Configuration
PORT=3001
NODE_ENV=production

# Database (Docker service name or external RDS)
DB_HOST=postgres
DB_PORT=5432
DB_NAME=chatcall
DB_USER=chatcall_user
DB_PASSWORD=CHANGE_THIS_STRONG_PASSWORD

# Redis (Docker service name or ElastiCache)
REDIS_HOST=redis
REDIS_PORT=6379

# JWT Secrets (IMPORTANT: Generate strong random secrets!)
# Generate with: openssl rand -base64 32
JWT_SECRET=CHANGE_THIS_TO_RANDOM_SECRET_32_CHARS
JWT_REFRESH_SECRET=CHANGE_THIS_TO_ANOTHER_RANDOM_SECRET_32_CHARS
JWT_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# mediasoup Configuration
# IMPORTANT: Set this to your server's PUBLIC IP or domain
MEDIASOUP_ANNOUNCED_IP=YOUR_LIGHTSAIL_STATIC_IP_HERE

# TURN/STUN Server
# IMPORTANT: Set this to your server's PUBLIC IP
TURN_SERVER_URL=turn:YOUR_LIGHTSAIL_STATIC_IP_HERE:3478
TURN_USERNAME=chatcall
TURN_PASSWORD=GENERATE_STRONG_TURN_PASSWORD_HERE

# Client URL (your domain or IP)
CLIENT_URL=https://yourdomain.com

# Email Configuration (Gmail SMTP)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com
SMTP_PASS=your-gmail-app-password
SMTP_FROM=your-email@gmail.com

# File Uploads
UPLOAD_DIR=../uploads
MAX_FILE_SIZE=10485760

# Optional: Monitoring
# LOG_LEVEL=info
